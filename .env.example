# ====== CLIENT-SIDE PUBLIC VARIABLES ======
# Exposed to Vite/React directly
VITE_TURNSTILE_SITE_KEY=your_public_site_key

# ====== SERVER-SIDE SECRET VARIABLES ======
# NEVER prefix these with VITE_ to avoid leaking to frontend
# Accessed only inside api/submit-lead.js

# Supabase Admin access (bypasses RLS)
SUPABASE_URL=https://[YOUR_PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare Turnstile Verification
TURNSTILE_SECRET_KEY=1x000...

# Resend API and Email config
RESEND_API_KEY=re_...
ADMIN_EMAIL=your_admin_inbox@trouvable.ca
FROM_EMAIL=Trouvable <onboarding@resend.dev>
